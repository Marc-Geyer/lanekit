# ─────────────────────────────────────────────────────────────────────────────
# LaneKit – Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Branding ──────────────────────────────────────────────────────────────────
# Your club / organisation name – shown in the navbar and page titles.
ORGANISATION_NAME=Schwimm e.V.

# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True

# Your public domain (used for CSRF protection and SSL certificate).
# No https:// prefix, no trailing slash.
DOMAIN=lanekit.example.com

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=lanekit
DB_USER=lanekit
DB_PASSWORD=lanekit

# ── Redis (WebSocket channel layer) ───────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── First-boot superuser (created automatically on first `docker compose up`) ─
# Remove these lines after the first start – they are not needed again.
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=admin

# ── Certbot / Let's Encrypt ───────────────────────────────────────────────────
# E-mail address for expiry notifications from Let's Encrypt.
CERTBOT_EMAIL=you@example.com

# Set to "--staging" to test against the Let's Encrypt staging server
# (unlimited requests, but browsers will show a warning).
# Set to "" (empty) for a real certificate.
CERTBOT_STAGING_FLAG=--staging
